# Copy to backend/.env for local development.
# Keep real keys out of git and out of frontend code.

# Optional. If omitted, the backend returns safe deterministic mock suggestions.
OPENAI_API_KEY=

# Optional. Use any structured-output-capable model available to your account.
OPENAI_MODEL=gpt-4o-mini

# Comma-separated list of allowed browser origins for local frontend dev.
AI_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional placeholder for a future backend error-monitoring SDK.
ERROR_MONITORING_DSN=
